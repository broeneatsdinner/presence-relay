# Example environment for the home LAN presence-relay target.
# Keep the live copy outside version control.

EVENT_BIND_HOST=127.0.0.1
EVENT_BIND_PORT=9001
EVENT_AUTH_TOKEN=replace-with-long-random-token
EVENT_DB_PATH=/opt/presence-relay/home-lan-target/presence-relay/db/presence.sqlite
WEB_VIEWER_BIND_HOST=127.0.0.1
WEB_VIEWER_BIND_PORT=9002
LOG_LEVEL=INFO
